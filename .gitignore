!/.config/hypr/workspaces.conf
!/.config/hypr/wall0.png
!/.config/hypr/wall1.png
!/.config/hypr/wall2.png
!/.config/hypr/scripts/
!/.config/hypr/scripts/*

# .config/opencode
!/.config/opencode/
!/.config/opencode/AGENTS.md
!/.config/opencode/opencode.json
!/.config/opencode/instructions/
