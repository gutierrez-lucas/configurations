# Ignore everything
*

# Unignore tracked files and their parent directories

# Dotfiles
!/.p10k.zsh
!/.tmux.conf
!/.zshrc

#documentation
!/.documentation/

# .config/alacritty
!/.config/
!/.config/alacritty/
!/.config/alacritty/alacritty.toml

# .config/nvim
!/.config/nvim/
!/.config/nvim/*
!/.config/nvim/lua/
!/.config/nvim/lua/*
!/.config/nvim/lua/config/
!/.config/nvim/lua/config/*
!/.config/nvim/lua/plugins/
!/.config/nvim/lua/plugins/*
!/.config/nvim/lua/user/
!/.config/nvim/lua/user/*

# .tmux
!/.tmux/**
