# Ignore everything
*

# Unignore tracked files and their parent directories

# Dotfiles
!/.p10k.zsh
!/.tmux.conf
!/.zshrc

#documentation
!/.documentation/
!/.documentation/*

#scripts
!/.scripts/
!./scripts/*

# .config/alacritty
!/.config/
!/.config/alacritty/
!/.config/alacritty/alacritty.toml

# .config/nvim
!/.config/nvim/lua/
!/.config/nvim/lua/*
!/.config/nvim/lua/config/
!/.config/nvim/lua/config/*
!/.config/nvim/lua/plugins/
!/.config/nvim/lua/plugins/*
!/.config/nvim/lua/user/
!/.config/nvim/lua/user/*

# .tmux
!/.tmux/**

# .config/opencode
!/.config/opencode/
!/.config/opencode/AGENTS.md
!/.config/opencode/instructions/
!/.config/opencode/instructions/*
