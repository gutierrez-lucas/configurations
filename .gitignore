# Ignore everything
*

# Unignore tracked files and their parent directories

# Dotfiles
!/.p10k.zsh
!/.tmux.conf
!/.zshrc
!/.fzf.zsh

#documentation
!/.documentation/
!/.documentation/*

#scripts
!/.scripts/
!/.scripts/*
!/.scripts/projects/
!/.scripts/projects/*

# .config/alacritty
!/.config/
!/.config/alacritty/
!/.config/alacritty/alacritty.toml

# .config/nvim
!/.config/nvim/
!/.config/nvim/lazyvim.json
!/.config/nvim/lua/
!/.config/nvim/lua/*
!/.config/nvim/lua/config/
!/.config/nvim/lua/config/*
!/.config/nvim/lua/plugins/
!/.config/nvim/lua/plugins/*
!/.config/nvim/lua/user/
!/.config/nvim/lua/user/*

# .tmux
!/.tmux/
!/.tmux/.gitignore
!/.tmux/plugins/
!/.tmux/plugins/tmux2k/
!/.tmux/plugins/tmux2k/plugins/
!/.tmux/plugins/tmux2k/plugins/*

# .config/hypr
!/.config/hypr/
!/.config/hypr/hyperidle
!/.config/hypr/hypridle.conf
!/.config/hypr/hyprland.conf
!/.config/hypr/hyprlock.conf
